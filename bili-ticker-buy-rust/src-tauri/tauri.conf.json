{
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devPath": "http://localhost:1420",
        "distDir": "../dist"
    },
    "package": {
        "productName": "BiliTickerBuy",
        "version": "0.0.0"
    },
    "tauri": {
        "allowlist": {
            "all": true
        },
        "bundle": {
            "active": true,
            "targets": "all",
            "identifier": "com.bilibili.ticker-buy",
            "icon": [
                "icons/32x32.png",
                "icons/128x128.png",
                "icons/128x128@2x.png",
                "icons/icon.icns",
                "icons/icon.ico"
            ]
        },
        "security": {
            "csp": null
        },
        "windows": [
            {
                "title": "BiliTickerBuy Rust",
                "fullscreen": false,
                "resizable": true,
                "width": 1024,
                "height": 768
            }
        ]
    }
}